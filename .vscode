{
    "configurations": [
        {
            "name": "FlyingFan",
            "includePath": [
                "${workspaceFolder}/**",
                "${userHome}/scoop/apps/avr-gcc/current/avr/include"
            ],
            "defines": [
                "__AVR_ATmega328P__",
                "F_CPU=16000000UL"
            ],
            "forcedInclude": [
                "${userHome}/scoop/apps/avr-gcc/current/avr/include/avr/iom328p.h"
            ],
            "compilerPath": "${userHome}/scoop/apps/avr-gcc/current/bin/avr-gcc.exe",
            "intelliSenseMode": "windows-gcc-x64",
            "compilerArgs": [
                "-mmcu=atmega328p"
            ]
        }
    ],
    "version": 4
}